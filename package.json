{
  "name": "paloma-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:frontend": "next dev",
    "dev:backend": "npm --prefix backend run start:dev",
    "build": "next build",
    "build:frontend": "next build",
    "build:backend": "npm --prefix backend run build",
    "start": "next start",
    "start:frontend": "next start",
    "start:backend": "npm --prefix backend run start",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down -v",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "15.5.14",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
