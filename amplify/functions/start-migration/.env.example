# Environment Variables for Start Migration Function

# Target GitHub organization that will receive the migrated repository
TARGET_ORGANIZATION=your-target-organization

# Personal Access Token with admin access to the source repository on GitHub.com
# Required scopes: repo, read:org
SOURCE_ADMIN_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Personal Access Token with admin access to the target organization on GitHub Enterprise Cloud
# Required scopes: repo, admin:org, workflow
TARGET_ADMIN_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
