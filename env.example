# Required: GitHub Personal Access Tokens
SOURCE_ADMIN_TOKEN=ghp_your_source_pat_here
TARGET_ADMIN_TOKEN=ghp_your_target_pat_here

# Required: Target GitHub organization name
TARGET_ORGANIZATION=my-target-org

# Display labels shown in the UI
TARGET_DESCRIPTION=Target GitHub Enterprise Cloud
SOURCE_DESCRIPTION=Source GitHub Organization

# Migration mode: GH (GitHub.com → GitHub.com) or GHES (GHES → GitHub.com)
MODE=GH

# Required when MODE=GHES
# GHES_API_URL=https://github.example.com/api/v3
